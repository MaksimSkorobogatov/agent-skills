# =============================================================================
# Git Worktree Helpers
# =============================================================================

.PHONY: worktree merge-worktree

# --- Configuration ------------------------------------------------------------

# Current branch.
CURRENT_BRANCH := $(shell git branch --show-current 2>/dev/null)

# Primary worktree path.
# In normal repositories this is the first entry returned by `git worktree list`.
PRIMARY_WORKTREE := $(shell git worktree list --porcelain 2>/dev/null | awk '/^worktree / { sub(/^worktree /, ""); print; exit }')

# Current repository root, useful as fallback.
CURRENT_REPO_ROOT := $(shell git rev-parse --show-toplevel 2>/dev/null)

# Repository root used by these helpers.
# Prefer the primary worktree so commands behave correctly even if invoked from
# a linked worktree.
REPO_ROOT := $(if $(PRIMARY_WORKTREE),$(PRIMARY_WORKTREE),$(CURRENT_REPO_ROOT))

# Base branch to create worktree from or merge into.
# Override: make worktree BRANCH=feat BASE_BRANCH=main
# Override: make merge-worktree BRANCH=feat BASE_BRANCH=main
BASE_BRANCH ?= $(CURRENT_BRANCH)

# Name of new branch / worktree branch.
BRANCH ?=

# Directory for worktrees, relative to REPO_ROOT.
WORKTREE_DIR ?= .worktrees

# Files/directories, space-separated, to symlink into the new worktree.
# Example: make worktree BRANCH=feat LINK_FILES=".env node_modules vendor"
LINK_FILES ?=

# Whether merge-worktree should push BASE_BRANCH after merge.
# Override: make merge-worktree BRANCH=feat BASE_BRANCH=main PUSH=0
PUSH ?= 1

# Whether merge-worktree should delete the local branch after successful merge
# and worktree removal.
# Override: make merge-worktree BRANCH=feat BASE_BRANCH=main DELETE_BRANCH=1
DELETE_BRANCH ?= 0

# Absolute path to new worktree.
WORKTREE_ABS = $(REPO_ROOT)/$(WORKTREE_DIR)/$(BRANCH)

## Note: Add this help target to the Makefile if it is missing there or not working properly.
# --- Help ---------------------------------------------------------------------

#help: ## Show available commands
#	@awk 'BEGIN {FS = ":.*?## "} /^[a-zA-Z_-]+:.*?## / {printf "\033[36m%-20s\033[0m %s\n", $$1, $$2}' $(MAKEFILE_LIST)


# --- 1. Create worktree -------------------------------------------------------

worktree: ## Create worktree from BASE_BRANCH and symlink LINK_FILES
ifeq ($(BRANCH),)
	@echo "Error: Specify BRANCH. Example: make worktree BRANCH=my-feature"
	@exit 1
endif
ifeq ($(BASE_BRANCH),)
	@echo "Error: Cannot detect current branch. Specify BASE_BRANCH=..."
	@exit 1
endif
ifeq ($(BRANCH),$(BASE_BRANCH))
	@echo "Error: BRANCH and BASE_BRANCH must differ ($(BASE_BRANCH))"
	@exit 1
endif
	@set -e; \
	if [ -z "$(REPO_ROOT)" ]; then \
		echo "Error: Must run inside a git repository."; \
		exit 1; \
	fi; \
	if git -C "$(REPO_ROOT)" show-ref --verify --quiet "refs/heads/$(BRANCH)" 2>/dev/null; then \
		echo "Error: Local branch '$(BRANCH)' already exists."; \
		exit 1; \
	fi; \
	if [ -e "$(WORKTREE_ABS)" ] || [ -L "$(WORKTREE_ABS)" ]; then \
		echo "Error: Path already exists: $(WORKTREE_ABS)"; \
		exit 1; \
	fi; \
	mkdir -p "$$(dirname "$(WORKTREE_ABS)")"; \
	if [ -f "$(REPO_ROOT)/.gitignore" ] && ! grep -qxF "$(WORKTREE_DIR)/" "$(REPO_ROOT)/.gitignore"; then \
		echo "$(WORKTREE_DIR)/" >> "$(REPO_ROOT)/.gitignore"; \
	fi; \
	echo "Creating worktree '$(BRANCH)' from '$(BASE_BRANCH)'..."; \
	git -C "$(REPO_ROOT)" worktree add -b "$(BRANCH)" "$(WORKTREE_ABS)" "$(BASE_BRANCH)"; \
	echo "Creating symlinks for LINK_FILES..."; \
	for item in $(LINK_FILES); do \
		src="$(REPO_ROOT)/$$item"; \
		dst="$(WORKTREE_ABS)/$$item"; \
		if [ ! -e "$$src" ] && [ ! -L "$$src" ]; then \
			echo "   skip (not found): $$item"; \
			continue; \
		fi; \
		mkdir -p "$$(dirname "$$dst")"; \
		if [ -e "$$dst" ] || [ -L "$$dst" ]; then \
			echo "   skip (already exists): $$item"; \
		else \
			ln -s "$$src" "$$dst"; \
			echo "   ok: $$item"; \
		fi; \
	done; \
	echo ""; \
	echo "Done: $(WORKTREE_ABS)"; \
	echo "cd $(WORKTREE_ABS)"


# --- 2. Merge worktree --------------------------------------------------------

merge-worktree: ## Safely merge BRANCH into BASE_BRANCH and remove worktree
ifeq ($(BRANCH),)
	@echo "Error: Specify BRANCH. Example: make merge-worktree BRANCH=my-feature BASE_BRANCH=main"
	@exit 1
endif
ifeq ($(BASE_BRANCH),)
	@echo "Error: Cannot detect BASE_BRANCH. Specify BASE_BRANCH=..."
	@exit 1
endif
ifeq ($(BRANCH),$(BASE_BRANCH))
	@echo "Error: BRANCH and BASE_BRANCH must differ ($(BASE_BRANCH))"
	@exit 1
endif
	@set -e; \
	if [ -z "$(REPO_ROOT)" ]; then \
		echo "Error: Must run inside a git repository."; \
		exit 1; \
	fi; \
	if ! git -C "$(REPO_ROOT)" show-ref --verify --quiet "refs/heads/$(BRANCH)" 2>/dev/null; then \
		echo "Error: Local branch '$(BRANCH)' does not exist."; \
		exit 1; \
	fi; \
	if ! git -C "$(REPO_ROOT)" show-ref --verify --quiet "refs/heads/$(BASE_BRANCH)" 2>/dev/null; then \
		echo "Error: Local base branch '$(BASE_BRANCH)' does not exist."; \
		exit 1; \
	fi; \
	WT=$$(git -C "$(REPO_ROOT)" worktree list --porcelain | \
		awk '/^worktree / { sub(/^worktree /, ""); p=$$0 } \
		     /^branch /  { sub(/^branch /, ""); if ($$0 == "refs/heads/$(BRANCH)") print p }'); \
	if [ -z "$$WT" ]; then \
		echo "Error: Worktree for branch '$(BRANCH)' not found."; \
		echo "This target is intended for branches checked out as git worktrees."; \
		exit 1; \
	fi; \
	echo "Found worktree: $$WT"; \
	ROOT_REAL=$$(cd "$(REPO_ROOT)" && pwd -P); \
	WT_REAL=$$(cd "$$WT" && pwd -P); \
	if [ "$$ROOT_REAL" = "$$WT_REAL" ]; then \
		echo "Error: Branch '$(BRANCH)' is checked out in the main worktree."; \
		echo "Refusing to merge/remove the main worktree."; \
		exit 1; \
	fi; \
	if git -C "$(REPO_ROOT)" rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then \
		echo "Error: Main worktree has an unfinished merge."; \
		echo "Resolve it in $(REPO_ROOT) before running merge-worktree."; \
		exit 1; \
	fi; \
	if git -C "$(REPO_ROOT)" rev-parse -q --verify REBASE_HEAD >/dev/null 2>&1; then \
		echo "Error: Main worktree has an unfinished rebase."; \
		echo "Resolve it in $(REPO_ROOT) before running merge-worktree."; \
		exit 1; \
	fi; \
	git -C "$$WT" update-index -q --refresh || true; \
	WT_STATUS=$$(git -C "$$WT" status --porcelain --untracked-files=all); \
	if [ -n "$$WT_STATUS" ]; then \
		echo "Error: Worktree for branch '$(BRANCH)' has uncommitted or untracked files."; \
		echo ""; \
		echo "Git status for $$WT:"; \
		printf '%s\n' "$$WT_STATUS"; \
		echo ""; \
		echo "Commit intended changes before merging:"; \
		echo "   cd $$WT"; \
		echo "   git add -A"; \
		echo "   git commit -m \"Describe changes\""; \
		echo ""; \
		echo "Or remove/generated unwanted files, then rerun:"; \
		echo "   make merge-worktree BRANCH=$(BRANCH) BASE_BRANCH=$(BASE_BRANCH)"; \
		echo ""; \
		echo "No merge, push, or cleanup was performed."; \
		exit 1; \
	fi; \
	git -C "$(REPO_ROOT)" update-index -q --refresh || true; \
	ROOT_STATUS=$$(git -C "$(REPO_ROOT)" status --porcelain --untracked-files=all); \
	if [ -n "$$ROOT_STATUS" ]; then \
		echo "Error: Main worktree has uncommitted or untracked files."; \
		echo ""; \
		echo "Git status for $(REPO_ROOT):"; \
		printf '%s\n' "$$ROOT_STATUS"; \
		echo ""; \
		echo "Commit, stash, or clean these changes before merging."; \
		echo "No merge, push, or cleanup was performed."; \
		exit 1; \
	fi; \
	echo "Switching main worktree to $(BASE_BRANCH)..."; \
	git -C "$(REPO_ROOT)" checkout "$(BASE_BRANCH)" || { \
		echo "Error: Failed to checkout $(BASE_BRANCH). Save changes and retry."; \
		exit 1; \
	}; \
	echo "Updating $(BASE_BRANCH) from origin with --ff-only..."; \
	git -C "$(REPO_ROOT)" pull --ff-only origin "$(BASE_BRANCH)" || { \
		echo "Error: Failed to update $(BASE_BRANCH) with --ff-only."; \
		echo "Resolve the branch state manually, then retry."; \
		exit 1; \
	}; \
	echo "Merging $(BRANCH) into $(BASE_BRANCH)..."; \
	git -C "$(REPO_ROOT)" merge "$(BRANCH)" || { \
		echo "Error: Merge conflict or merge failure."; \
		echo "Resolve in $(REPO_ROOT) and finish manually."; \
		echo "The worktree was not removed."; \
		exit 1; \
	}; \
	if [ "$(PUSH)" = "1" ]; then \
		echo "Pushing $(BASE_BRANCH)..."; \
		git -C "$(REPO_ROOT)" push origin "$(BASE_BRANCH)" || { \
			echo "Error: Failed to push $(BASE_BRANCH)."; \
			echo "The worktree was not removed so you can inspect/retry safely."; \
			exit 1; \
		}; \
	else \
		echo "Skipping push because PUSH=0."; \
	fi; \
	echo "Removing worktree $$WT..."; \
	git -C "$(REPO_ROOT)" worktree remove "$$WT" || { \
		echo "Warning: Could not auto-remove worktree."; \
		echo ""; \
		echo "Inspect it before removing manually:"; \
		echo "   git -C $$WT status --short"; \
		echo ""; \
		echo "If it is clean and safe to remove:"; \
		echo "   git worktree remove $$WT"; \
		exit 1; \
	}; \
	if [ "$(DELETE_BRANCH)" = "1" ]; then \
		echo "Deleting local branch $(BRANCH)..."; \
		git -C "$(REPO_ROOT)" branch -d "$(BRANCH)" || { \
			echo "Warning: Could not delete branch '$(BRANCH)'."; \
			echo "You can delete it manually later if safe:"; \
			echo "   git branch -d $(BRANCH)"; \
			exit 1; \
		}; \
	else \
		echo "Keeping local branch $(BRANCH). Use DELETE_BRANCH=1 to delete after merge."; \
	fi; \
	echo ""; \
	echo "Done: Branch '$(BRANCH)' merged into '$(BASE_BRANCH)'."; \
	echo "Back to root: cd $(REPO_ROOT)"
